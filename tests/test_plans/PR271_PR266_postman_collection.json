{
	"info": {
		"name": "PR #271 + PR #266 — Flex Due Date & Connect Account",
		"description": "Test collection for services PR #271 (Flex bill due_date fallback → today+20) and PR #266 (new /connect-account endpoint + upsert-credentials changes).\n\nReplace collection variables before running.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "ADMIN_URL",
			"value": "https://your-admin-router-url.example.com",
			"description": "Admin Router base URL (check SST/infra config)"
		},
		{
			"key": "FLEX_BILL_ENDPOINT",
			"value": "https://your-flex-bill-endpoint.example.com/bill",
			"description": "Flex bill API endpoint URL"
		},
		{
			"key": "API_KEY",
			"value": "your-api-key-here",
			"description": "Authorization header value for admin endpoints"
		},
		{
			"key": "USER_ID",
			"value": "00000000-0000-0000-0000-000000000000",
			"description": "Test user UUID with ElectricAccount and GasAccount"
		},
		{
			"key": "USER_ID_NO_BILLS",
			"value": "00000000-0000-0000-0000-000000000000",
			"description": "Flex user UUID with no bills / zero balance"
		},
		{
			"key": "USER_ID_WITH_BILLS",
			"value": "00000000-0000-0000-0000-000000000000",
			"description": "Flex user UUID with real dueDate values on bills"
		},
		{
			"key": "USER_EMAIL",
			"value": "testuser@example.com",
			"description": "Email for the test user"
		}
	],
	"item": [
		{
			"name": "PR #271 — Flex Due Date",
			"description": "Verify all 3 fallback due_date values changed from 0/14 → 20 days",
			"item": [
				{
					"name": "TC-003: Test mode mock bill (today+20)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{FLEX_BILL_ENDPOINT}}?test=true",
							"host": ["{{FLEX_BILL_ENDPOINT}}"],
							"query": [
								{ "key": "test", "value": "true" }
							]
						},
						"description": "Easiest to verify — no user setup needed. Mock bill should return due_date ≈ today+20 and amount_due_in_cents = 22500."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('due_date is ~today+20', () => {",
									"    const body = pm.response.json();",
									"    const dueDate = new Date(body.due_date);",
									"    const expected = new Date();",
									"    expected.setDate(expected.getDate() + 20);",
									"    const diffDays = Math.abs((dueDate - expected) / (1000*60*60*24));",
									"    pm.expect(diffDays).to.be.below(2, 'due_date should be ~20 days from today');",
									"});",
									"",
									"pm.test('amount_due_in_cents is 22500', () => {",
									"    pm.expect(pm.response.json().amount_due_in_cents).to.eql(22500);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "TC-001: Flex user — NULL due dates (today+20)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{FLEX_BILL_ENDPOINT}}?userId={{USER_ID}}",
							"host": ["{{FLEX_BILL_ENDPOINT}}"],
							"query": [
								{ "key": "userId", "value": "{{USER_ID}}" }
							]
						},
						"description": "Flex user whose bills have NULL dueDate values. Fallback should return due_date ≈ today+20."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('due_date is ~today+20', () => {",
									"    const body = pm.response.json();",
									"    const dueDate = new Date(body.due_date);",
									"    const expected = new Date();",
									"    expected.setDate(expected.getDate() + 20);",
									"    const diffDays = Math.abs((dueDate - expected) / (1000*60*60*24));",
									"    pm.expect(diffDays).to.be.below(2, 'due_date should be ~20 days from today');",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "TC-002: Flex user — no bills (today+20, $0)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{FLEX_BILL_ENDPOINT}}?userId={{USER_ID_NO_BILLS}}",
							"host": ["{{FLEX_BILL_ENDPOINT}}"],
							"query": [
								{ "key": "userId", "value": "{{USER_ID_NO_BILLS}}" }
							]
						},
						"description": "Flex user with no bills / zero balance. Should return due_date ≈ today+20 and amount_due_in_cents = 0."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('due_date is ~today+20', () => {",
									"    const body = pm.response.json();",
									"    const dueDate = new Date(body.due_date);",
									"    const expected = new Date();",
									"    expected.setDate(expected.getDate() + 20);",
									"    const diffDays = Math.abs((dueDate - expected) / (1000*60*60*24));",
									"    pm.expect(diffDays).to.be.below(2);",
									"});",
									"",
									"pm.test('amount_due_in_cents is 0', () => {",
									"    pm.expect(pm.response.json().amount_due_in_cents).to.eql(0);",
									"});"
								]
							}
						}
					]
				},
				{
					"name": "TC-004: Flex user — real due dates (regression)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{FLEX_BILL_ENDPOINT}}?userId={{USER_ID_WITH_BILLS}}",
							"host": ["{{FLEX_BILL_ENDPOINT}}"],
							"query": [
								{ "key": "userId", "value": "{{USER_ID_WITH_BILLS}}" }
							]
						},
						"description": "Regression — flex user with real dueDate values. Response should use the actual earliest due date, NOT the +20 day fallback."
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status is 200', () => pm.response.to.have.status(200));",
									"",
									"pm.test('due_date is NOT today+20 (uses real date)', () => {",
									"    const body = pm.response.json();",
									"    const dueDate = new Date(body.due_date);",
									"    const fallback = new Date();",
									"    fallback.setDate(fallback.getDate() + 20);",
									"    const diffDays = Math.abs((dueDate - fallback) / (1000*60*60*24));",
									"    // If it's more than 2 days away from today+20, it's using a real date",
									"    pm.expect(diffDays).to.be.above(1, 'due_date should be a real bill date, not the +20 fallback');",
									"});"
								]
							}
						}
					]
				}
			]
		},
